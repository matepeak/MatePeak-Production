# ====================================
# MatePeak - Environment Variables
# ====================================
# 
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!
#
# Notes:
# - All VITE_* variables are exposed to the client
# - Keep sensitive keys out of VITE_* variables
# - Restart dev server after changing environment variables
#
# ====================================

# ====================================
# REQUIRED: Supabase Configuration
# ====================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# Documentation: https://supabase.com/docs/guides/getting-started

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id

# ====================================
# OPTIONAL: Feature Flags
# ====================================

# Enable AI-powered mentor search (requires OpenAI API key in Supabase Edge Functions)
VITE_ENABLE_AI_SEARCH=false

# Enable real-time features (messaging, notifications)
VITE_ENABLE_REALTIME=true

# Enable email notifications
VITE_ENABLE_EMAIL_NOTIFICATIONS=false

# Enable SMS notifications (requires Twilio setup)
VITE_ENABLE_SMS_NOTIFICATIONS=false

# ====================================
# OPTIONAL: Payment Configuration
# ====================================

# Payment provider (razorpay or stripe)
VITE_PAYMENT_PROVIDER=razorpay

# Razorpay public key (if using Razorpay)
# VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Stripe publishable key (if using Stripe)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# ====================================
# OPTIONAL: Analytics & Monitoring
# ====================================

# Google Analytics Measurement ID (format: G-XXXXXXXXXX)
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Sentry DSN for error tracking
# VITE_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ====================================
# OPTIONAL: External Services
# ====================================

# Video calling service (daily, zoom, or custom)
# VITE_VIDEO_PROVIDER=daily
# VITE_DAILY_API_KEY=your-daily-api-key

# File upload service
# VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
# VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# ====================================
# DEVELOPMENT: Local Settings
# ====================================

# Node environment (development, production, test)
NODE_ENV=development

# API timeout in milliseconds
VITE_API_TIMEOUT=30000

# Enable debug logging
VITE_DEBUG_MODE=false

# ====================================
# DEPLOYMENT: Platform-Specific
# ====================================

# Vercel deployment settings (automatically set by Vercel)
# VERCEL_URL=
# VERCEL_ENV=

# Base URL for the application (used for redirects, emails)
# VITE_APP_URL=https://matepeak.com
